rules_version = '2';

// Firestore security rules for this project.
//
// Deploy via Firebase Console (Firestore → Rules) or with Firebase CLI:
//   firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------
    // Users (profile + stats)
    // -----------------------------
    // Stores private user data (email, account-related fields) and game stats used for syncing.
    // This collection is intentionally private: users can only read/write their own document.
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // -----------------------------
    // Game history
    // -----------------------------
    // Note: these rules allow any authenticated user to read any game history document.
    // If game history should be private per user, tighten this rule (e.g. store an owner uid and check it).
    match /GameHistory/{gameId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    // -----------------------------
    // Legacy leaderboard collection
    // -----------------------------
    // Kept for backwards compatibility. If not used, consider removing this collection and its rules.
    match /Leaderboard/{leaderboard} {
      allow create: if false;
      allow read: if true;
      allow update: if false;
      allow delete: if false;
    }

    // -----------------------------
    // Public leaderboard (materialized)
    // -----------------------------
    // Leaderboard collection intended for display in the app.
    // In this project we accept client-side writes (no paid backend). This is NOT cheat-proof.
    match /leaderboard_maxStreak/{uid} {
      allow read: if true;
      // Only the signed-in owner may create/update their own leaderboard entry.
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // -----------------------------
    // Words (game content)
    // -----------------------------
    // Public read-only word banks used by the game.
    match /Words/{language} {
      allow create: if false;
      allow read: if true;
      allow update: if false;
      allow delete: if false;
    }
  }
}
